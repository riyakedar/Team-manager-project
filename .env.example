# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio can inject this at runtime from user secrets.
GEMINI_API_KEY="your_gemini_api_key"

# MONGODB_URI: Connection string for MongoDB (local or Atlas).
MONGODB_URI="mongodb://localhost:27017/team-task-manager"

# MONGODB_DB_NAME: Optional. Used when your URI does not include a database path.
MONGODB_DB_NAME="team-task-manager"

# JWT_SECRET: Secret key for signing JSON Web Tokens.
JWT_SECRET="replace_with_a_long_random_secret"
